# Minimal local i4h agent settings.
# Override any value in your shell before running ./local-agent/run.sh.

export I4H_AGENT_PROFILE="${I4H_AGENT_PROFILE:-qwen3-coder-next}"

_i4h_default_single_gpu() {
    local preferred="${1:-1}"
    local fallback="${2:-0}"
    local gpu_index

    if command -v nvidia-smi >/dev/null 2>&1; then
        while IFS= read -r gpu_index; do
            gpu_index="${gpu_index// /}"
            [[ "${gpu_index}" == "${preferred}" ]] && { echo "${preferred}"; return; }
        done < <(nvidia-smi --query-gpu=index --format=csv,noheader 2>/dev/null || true)
    fi

    echo "${fallback}"
}

case "${I4H_AGENT_PROFILE}" in
    nvidia-hosted)
        # Remote NVIDIA-hosted NIM endpoint (no local GPU / Docker needed).
        # Requires I4H_AGENT_API_KEY=nvapi-... in the environment.
        # Override I4H_AGENT_MODEL to pick a different hosted model.
        _i4h_default_base_url="https://inference-api.nvidia.com"
        _i4h_default_model="azure/openai/gpt-5.5"
        _i4h_default_served_name="azure/openai/gpt-5.5"
        _i4h_default_image=""
        _i4h_default_gpu=""
        _i4h_default_skill_gpu="0"
        _i4h_default_gpu_util="0"
        _i4h_default_max_model_len="202752"
        _i4h_default_shm_size=""
        _i4h_default_startup_timeout="0"
        _i4h_default_tp_size="1"
        _i4h_default_output_limit="16384"
        _i4h_default_tool_call_parser=""
        _i4h_default_reasoning_parser=""
        _i4h_default_trust_remote_code="0"
        _i4h_default_prelaunch=""
        ;;
    nemotron)
        _i4h_default_image="lmsysorg/sglang:dev-cu13-nemotronh-nano-omni-reasoning-v3"
        _i4h_default_model="nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16"
        _i4h_default_served_name="nemotron-3-nano-omni"
        _i4h_default_gpu="$(_i4h_default_single_gpu 1 0)"
        _i4h_default_skill_gpu="0"
        _i4h_default_gpu_util="0.85"
        _i4h_default_max_model_len="131072"
        _i4h_default_shm_size="16g"
        _i4h_default_startup_timeout="1800"
        _i4h_default_tp_size="1"
        _i4h_default_output_limit="20480"
        _i4h_default_tool_call_parser="qwen3_coder"
        _i4h_default_reasoning_parser="nemotron_3"
        _i4h_default_trust_remote_code="1"
        _i4h_default_prelaunch="pip install --break-system-packages librosa >/dev/null 2>&1 || true"
        ;;
    qwen3-coder-next|qwen-coder-next)
        # Default local profile: FP8 on one RTX PRO 6000, preserving GPU 0
        # for Isaac Sim / workflow commands when GPU 1 is available.
        _i4h_default_image="lmsysorg/sglang:latest"
        _i4h_default_model="Qwen/Qwen3-Coder-Next-FP8"
        _i4h_default_served_name="qwen3-coder-next"
        _i4h_default_gpu="$(_i4h_default_single_gpu 1 0)"
        _i4h_default_skill_gpu="0"
        _i4h_default_gpu_util="0.92"
        _i4h_default_max_model_len="262144"
        _i4h_default_shm_size="32g"
        _i4h_default_startup_timeout="2400"
        _i4h_default_tp_size="1"
        _i4h_default_output_limit="8192"
        _i4h_default_tool_call_parser="qwen3_coder"
        _i4h_default_reasoning_parser=""
        _i4h_default_trust_remote_code="0"
        _i4h_default_prelaunch=""
        ;;
    qwen3-coder-30b-fp8|qwen-coder-30b-fp8)
        # Smaller local profile for a single 48 GB GPU.
        _i4h_default_image="lmsysorg/sglang:latest"
        _i4h_default_model="Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8"
        _i4h_default_served_name="qwen3-coder-30b-fp8"
        _i4h_default_gpu="$(_i4h_default_single_gpu 1 0)"
        _i4h_default_skill_gpu="0"
        _i4h_default_gpu_util="0.55"
        _i4h_default_max_model_len="262144"
        _i4h_default_shm_size="24g"
        _i4h_default_startup_timeout="1800"
        _i4h_default_tp_size="1"
        _i4h_default_output_limit="8192"
        _i4h_default_tool_call_parser="qwen3_coder"
        _i4h_default_reasoning_parser=""
        _i4h_default_trust_remote_code="0"
        _i4h_default_prelaunch=""
        ;;
    qwen3-coder-next-bf16|qwen-coder-next-bf16)
        # Higher-quality test profile: uses both workstation GPUs, so don't run
        # Isaac Sim workloads at the same time.
        _i4h_default_image="lmsysorg/sglang:latest"
        _i4h_default_model="Qwen/Qwen3-Coder-Next"
        _i4h_default_served_name="qwen3-coder-next-bf16"
        _i4h_default_gpu="0,1"
        _i4h_default_skill_gpu="0"
        _i4h_default_gpu_util="0.85"
        _i4h_default_max_model_len="65536"
        _i4h_default_shm_size="32g"
        _i4h_default_startup_timeout="2400"
        _i4h_default_tp_size="2"
        _i4h_default_output_limit="20480"
        _i4h_default_tool_call_parser="qwen3_coder"
        _i4h_default_reasoning_parser=""
        _i4h_default_trust_remote_code="0"
        _i4h_default_prelaunch=""
        ;;
    *)
        echo "error: unknown I4H_AGENT_PROFILE='${I4H_AGENT_PROFILE}'" >&2
        echo "valid profiles: nvidia-hosted, nemotron, qwen3-coder-next, qwen3-coder-30b-fp8, qwen3-coder-next-bf16" >&2
        return 2 2>/dev/null || exit 2
        ;;
esac

export I4H_AGENT_IMAGE="${I4H_AGENT_IMAGE:-${_i4h_default_image}}"
export I4H_AGENT_MODEL="${I4H_AGENT_MODEL:-${_i4h_default_model}}"
export I4H_AGENT_DEFAULT_SERVED_NAME="${_i4h_default_served_name}"
export I4H_AGENT_SERVED_NAME="${I4H_AGENT_SERVED_NAME:-auto}"

export I4H_AGENT_PORT="${I4H_AGENT_PORT:-8001}"
export I4H_AGENT_BASE_URL="${I4H_AGENT_BASE_URL:-${_i4h_default_base_url:-http://127.0.0.1:${I4H_AGENT_PORT}}}"
# Bearer token for a remote OpenAI-compatible endpoint (e.g. NVIDIA NIM). When
# set, run.sh runs in remote mode: it talks to I4H_AGENT_BASE_URL with this key
# and does not start/manage a local Docker model server.
export I4H_AGENT_API_KEY="${I4H_AGENT_API_KEY:-}"

# Resilience timeouts (ms) written into opencode.json provider options. Hosted
# endpoints occasionally wedge a single request (no response bytes, no error);
# without a time-to-first-byte abort the agent hangs forever. headerTimeout aborts
# a zero-byte stall, chunkTimeout a mid-stream stall, timeout is the overall ceiling.
# On trip the turn errors cleanly ("SSE read timed out") and is re-runnable.
export I4H_AGENT_REQUEST_TIMEOUT_MS="${I4H_AGENT_REQUEST_TIMEOUT_MS:-600000}"
export I4H_AGENT_HEADER_TIMEOUT_MS="${I4H_AGENT_HEADER_TIMEOUT_MS:-90000}"
export I4H_AGENT_CHUNK_TIMEOUT_MS="${I4H_AGENT_CHUNK_TIMEOUT_MS:-90000}"

# Vision-language model for visual scene validation (bridge captures). The coding
# agent is not vision-capable, so it calls this endpoint via local-agent/vlcheck.py.
# Defaults to the NVIDIA-hosted Nemotron Nano 12B VL (no local VL GPU needed); reuses
# I4H_AGENT_API_KEY when I4H_AGENT_VL_API_KEY is unset. To self-host instead, set
# I4H_AGENT_VL_BASE_URL=http://localhost:8000 and I4H_AGENT_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct.
export I4H_AGENT_VL_BASE_URL="${I4H_AGENT_VL_BASE_URL:-https://inference-api.nvidia.com}"
export I4H_AGENT_VL_MODEL="${I4H_AGENT_VL_MODEL:-nvidia/nvidia/nemotron-nano-12b-v2-vl}"
export I4H_AGENT_VL_API_KEY="${I4H_AGENT_VL_API_KEY:-${I4H_AGENT_API_KEY:-}}"

export I4H_AGENT_GPU="${I4H_AGENT_GPU:-${_i4h_default_gpu}}"
export I4H_AGENT_SKILL_GPU="${I4H_AGENT_SKILL_GPU:-${_i4h_default_skill_gpu}}"

export I4H_AGENT_GPU_UTIL="${I4H_AGENT_GPU_UTIL:-${_i4h_default_gpu_util}}"
export I4H_AGENT_MAX_MODEL_LEN="${I4H_AGENT_MAX_MODEL_LEN:-${_i4h_default_max_model_len}}"
export I4H_AGENT_SHM_SIZE="${I4H_AGENT_SHM_SIZE:-${_i4h_default_shm_size}}"
export I4H_AGENT_STARTUP_TIMEOUT="${I4H_AGENT_STARTUP_TIMEOUT:-${_i4h_default_startup_timeout}}"
export I4H_AGENT_TP_SIZE="${I4H_AGENT_TP_SIZE:-${_i4h_default_tp_size}}"
export I4H_AGENT_OUTPUT_LIMIT="${I4H_AGENT_OUTPUT_LIMIT:-${_i4h_default_output_limit}}"
export I4H_AGENT_TOOL_CALL_PARSER="${I4H_AGENT_TOOL_CALL_PARSER:-${_i4h_default_tool_call_parser}}"
export I4H_AGENT_REASONING_PARSER="${I4H_AGENT_REASONING_PARSER:-${_i4h_default_reasoning_parser}}"
export I4H_AGENT_TRUST_REMOTE_CODE="${I4H_AGENT_TRUST_REMOTE_CODE:-${_i4h_default_trust_remote_code}}"
export I4H_AGENT_PRELAUNCH="${I4H_AGENT_PRELAUNCH:-${_i4h_default_prelaunch}}"

export I4H_AGENT_CONTAINER="${I4H_AGENT_CONTAINER:-i4h_local_agent}"
export I4H_AGENT_HF_CACHE="${I4H_AGENT_HF_CACHE:-${HOME}/.cache/huggingface}"
export I4H_AGENT_OPENCODE_BIN="${I4H_AGENT_OPENCODE_BIN:-opencode}"
export I4H_AGENT_DOCKER_RESTART="${I4H_AGENT_DOCKER_RESTART:-unless-stopped}"
export I4H_AGENT_WARMUP="${I4H_AGENT_WARMUP:-1}"
export I4H_AGENT_HF_OFFLINE="${I4H_AGENT_HF_OFFLINE:-auto}"
export I4H_AGENT_REPO_ROOT="${I4H_AGENT_REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
